7.Write a function odd_index_chars(text) that takes a string. Return a new string containing only the characters located at odd indices (1, 3, 5, etc.).

def odd_index_chars(text):
    answer = " "
    for i in range(len(text)):
        if i % 2 == 1:
            answer += text[i]
    return answer
print(odd_index_chars("Salam necesen"))

8.Write a function calculate_median(lst) that correctly finds the median of a list of numbers. It must handle both odd and even lengths. 

def calculate_median(first_num):
    first_num.sort()
    x = len(first_num)
    mid = x // 2

    if x % 2 == 1:
        return first_num[mid]
    else:
        return (first_num[mid - 1] + first_num[mid]) / 2
    
print(calculate_median([1, 3, 2]))
print(calculate_median([1, 2, 3, 5]))
    
9.Create a class DataScaler that implements a method normalize(self) to perform Min-Max Scaling on its internal list of numbers. Handle the case where Max = Min.                           
Min-Max normalization: (x - Min) / (Max - Min)

class DataScaler:
    def __init__(self, data):
        self.data = data

    def normalize(self):
        min_val = min(self.data)
        max_val = max(self.data)

        normalized = [(x - min_val) / (max_val - min_val) for x in self.data]
        return normalized

numbers = [10, 20, 30, 40, 50]
scaler = DataScaler(numbers)
print("Normalized data:", scaler.normalize())

10.Write a function conditional_sum(nested_list, condition_func) that uses nested loops to traverse the lists and filter() to select elements based on a provided condition function before summing them up. 

# Example Usage:
           data = [[1, 5, 10], [2, 8, 12], [3, 6, 9]]
	# Conditional statement (is_even)
	# Expected Output: 38 (10 + 2 + 8 + 12 + 6)


def conditional_sum(nested_list, condition_func):
    total = 0
    for inner_list in nested_list:
        filtered = filter(condition_func, inner_list)
        for x in filtered:
            total += x
    return total

def is_even(x):
    return x % 2 == 0

data = [[1, 5, 10], [2, 8, 12], [3, 6, 9]]
print(conditional_sum(data, is_even))







