6.Write a function that takes a string and returns the number of vowels in it.


def count_vowels(text):
    vowels = "aeiouAEIOU"
    count = 0
    for ch in text:
        if ch in vowels:
            count += 1
    return count

word = input("Enter a word or sentence: ")
