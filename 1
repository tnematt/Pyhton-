2	Write a program that calculates the sum of the main diagonal of a 2D list (square matrix). Example: 
 	 		                       

            Sum = 1 + 5 + 9 = 15

def diagonal_sum(matrix):
    total = 0
    for i in range(len(matrix)):
        total += matrix[i][i]
    return total

matrix = [
    [1, 2, 3],
    [4, 5, 6],
    [7, 8, 9]
]
print (diagonal_sum(matrix))

